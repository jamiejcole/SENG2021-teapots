MONGODB_URI=
MONGODB_DBNAME=
PORT=3002

# temp backend api key for /v1 routes, backwards compatibility
BACKEND_API_KEY=

# JWT config
JWT_SECRET=

# Mailgun config
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=
MAILGUN_URL=

# Mailgun templates
MAILGUN_2FA_TEMPLATE=
MAILGUN_INVOICE_TEMPLATE=
MAILGUN_PASSWORD_RESET_TEMPLATE=

# Mailgun links
MAILGUN_HELP_LINK=https://teapotinvoicing.app/support
MAILGUN_PRIVACY_LINK=https://teapotinvoicing.app/privacy
MAILGUN_SECURITY_LINK=https://teapotinvoicing.app/account
PUBLIC_APP_URL=https://teapotinvoicing.app
PUBLIC_HELP_URL=https://teapotinvoicing.app/support
PUBLIC_SETTINGS_URL=https://teapotinvoicing.app/account

# DevEx API  for tests
DEVEX_DESPATCH_API_KEY=

# AI features (Google Gemini 1.5 Flash - free tier) - required for /api/v2/ai/* endpoints
# Get your key free at: https://aistudio.google.com → Get API key (no credit card needed)
GEMINI_API_KEY=
