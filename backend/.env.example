MONGODB_URI=
MONGODB_DBNAME=
PORT=3002
# Must match VITE_API_KEY in frontend/app/.env
BACKEND_API_KEY=dev-local-key

# AI features (Google Gemini 1.5 Flash - free tier) - required for /api/v2/ai/* endpoints
