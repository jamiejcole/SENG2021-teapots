"AUD\">21500.00<\/cbc:TaxableAmount>\r\n            <cbc:TaxAmount currencyID=\"AUD\">2150.00<\/cbc:TaxAmount>\r\n            <cac:TaxCategory>\r\n                <cbc:ID>S<\/cbc:ID>\r\n                <cbc:Percent>10<\/cbc:Percent>\r\n                <cac:TaxScheme>\r\n                    <cbc:ID>GST<\/cbc:ID>\r\n                <\/cac:TaxScheme>\r\n            <\/cac:TaxCategory>\r\n        <\/cac:TaxSubtotal>\r\n    <\/cac:TaxTotal>\r\n    <cac:LegalMonetaryTotal>\r\n        <cbc:LineExtensionAmount currencyID=\"AUD\">21500.00<\/cbc:LineExtensionAmount>\r\n        <cbc:TaxExclusiveAmount currencyID=\"AUD\">21500.00<\/cbc:TaxExclusiveAmount>\r\n        <cbc:TaxInclusiveAmount currencyID=\"AUD\">23650.00<\/cbc:TaxInclusiveAmount>\r\n        <cbc:PayableAmount currencyID=\"AUD\">23650.00<\/cbc:PayableAmount>\r\n    <\/cac:LegalMonetaryTotal>\r\n    <cac:InvoiceLine>\r\n        <cbc:ID>1<\/cbc:ID>\r\n        <cbc:InvoicedQuantity unitCode=\"EA\">10<\/cbc:InvoicedQuantity>\r\n        <cbc:LineExtensionAmount currencyID=\"AUD\">15000.00<\/cbc:LineExtensionAmount>\r\n        <cac:OrderLineReference>\r\n            <cbc:LineID>1<\/cbc:LineID>\r\n        <\/cac:OrderLineReference>\r\n        <cac:Item>\r\n            <cbc:Name>ProBook Laptop 15-inch<\/cbc:Name>\r\n            <cac:ClassifiedTaxCategory>\r\n                <cbc:ID>S<\/cbc:ID>\r\n                <cbc:Percent>10<\/cbc:Percent>\r\n                <cac:TaxScheme>\r\n                    <cbc:ID>GST<\/cbc:ID>\r\n                <\/cac:TaxScheme>\r\n            <\/cac:ClassifiedTaxCategory>\r\n        <\/cac:Item>\r\n        <cac:Price>\r\n            <cbc:PriceAmount currencyID=\"AUD\">1500.00<\/cbc:PriceAmount>\r\n        <\/cac:Price>\r\n    <\/cac:InvoiceLine>\r\n    <cac:InvoiceLine>\r\n        <cbc:ID>2<\/cbc:ID>\r\n        <cbc:InvoicedQuantity unitCode=\"EA\">20<\/cbc:InvoicedQuantity>\r\n        <cbc:LineExtensionAmount currencyID=\"AUD\">6000.00<\/cbc:LineExtensionAmount>\r\n        <cac:OrderLineReference>\r\n            <cbc:LineID>2<\/cbc:LineID>\r\n        <\/cac:OrderLineReference>\r\n        <cac:Item>\r\n            <cbc:Name>UltraSharp 27-inch Monitor<\/cbc:Name>\r\n            <cac:ClassifiedTaxCategory>\r\n                <cbc:ID>S<\/cbc:ID>\r\n                <cbc:Percent>10<\/cbc:Percent>\r\n                <cac:TaxScheme>\r\n                    <cbc:ID>GST<\/cbc:ID>\r\n                <\/cac:TaxScheme>\r\n            <\/cac:ClassifiedTaxCategory>\r\n        <\/cac:Item>\r\n        <cac:Price>\r\n            <cbc:PriceAmount currencyID=\"AUD\">300.00<\/cbc:PriceAmount>\r\n        <\/cac:Price>\r\n    <\/cac:InvoiceLine>\r\n    <cac:InvoiceLine>\r\n        <cbc:ID>3<\/cbc:ID>\r\n        <cbc:InvoicedQuantity unitCode=\"EA\">1<\/cbc:InvoicedQuantity>\r\n        <cbc:LineExtensionAmount currencyID=\"AUD\">500.00<\/cbc:LineExtensionAmount>\r\n        <cac:OrderLineReference>\r\n            <cbc:LineID>3<\/cbc:LineID>\r\n        <\/cac:OrderLineReference>\r\n        <cac:Item>\r\n            <cbc:Name>On-site Hardware Installation<\/cbc:Name>\r\n            <cac:ClassifiedTaxCategory>\r\n                <cbc:ID>S<\/cbc:ID>\r\n                <cbc:Percent>10<\/cbc:Percent>\r\n                <cac:TaxScheme>\r\n                    <cbc:ID>GST<\/cbc:ID>\r\n                <\/cac:TaxScheme>\r\n            <\/cac:ClassifiedTaxCategory>\r\n        <\/cac:Item>\r\n        <cac:Price>\r\n            <cbc:PriceAmount currencyID=\"AUD\">500.00<\/cbc:PriceAmount>\r\n        <\/cac:Price>\r\n    <\/cac:InvoiceLine>\r\n<\/Invoice>
}

settings {
  encodeUrl: true
  timeout: 0
}
